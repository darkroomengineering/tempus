---
import Layout from '../layouts/Layout.astro'
---

<Layout title="Tempus — one rAF to rule them all">
  <canvas id="scope" style="opacity: 0.2;"></canvas>
  <div class="grain"></div>

  <section class="hero">
    <div class="metro" aria-hidden="true">
      <span class="metro-body"></span>
      <span class="metro-arm" id="metro-arm"><span class="metro-weight"></span></span>
      <span class="metro-pivot"></span>
    </div>

    <h1 class="wordmark">TEMPUS</h1>
    <p class="tagline">one rAF to rule them all</p>
    <p class="sub">
      /ˈtɛm.pʊs/ — Latin, “time”. The single heartbeat behind every frame:
      one loop, many callbacks, kept in order and in time.
    </p>
  </section>

  <div class="composition" id="composition" aria-hidden="true"></div>

  <footer class="readout">
    <div class="stat"><span class="k">fps</span><span class="v" id="r-fps">—</span></div>
    <div class="stat"><span class="k">frame</span><span class="v" id="r-frame">—</span></div>
    <div class="stat"><span class="k">budget</span><span class="v" id="r-budget">—</span></div>
    <label class="stat load">
      <span class="k">load</span>
      <input id="load" type="range" min="0" max="100" value="0" />
    </label>
    <button class="toggle" id="toggle" type="button" aria-label="Stop the loop">stop</button>
  </footer>

  <script src="../../landing/hero.ts"></script>
</Layout>

<style>
  :global(body) {
    background: #07070a;
    color: #f4f4f5;
    overflow: hidden;
  }

  #scope {
    position: fixed;
    inset: 0;
    width: 100vw;
    height: 100dvh;
    display: block;
  }

  /* faint CRT scanline / grain over the trace */
  .grain {
    position: fixed;
    inset: 0;
    pointer-events: none;
    background: repeating-linear-gradient(
      0deg,
      rgba(255, 255, 255, 0.02) 0 1px,
      transparent 1px 3px
    );
    mix-blend-mode: overlay;
  }

  .hero {
    position: relative;
    z-index: 2;
    min-height: 100dvh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 0 6vw;
    pointer-events: none;
  }

  .wordmark {
    margin: 0;
    font-family: Inter, system-ui, sans-serif;
    font-weight: 800;
    font-size: clamp(4rem, 17vw, 15rem);
    line-height: 0.85;
    letter-spacing: -0.045em;
    text-shadow: 0 0 60px rgba(255, 176, 0, 0.15);
    mix-blend-mode: screen;
  }

  .tagline {
    margin: 1.4rem 0 0;
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    text-transform: uppercase;
    letter-spacing: 0.42em;
    font-size: clamp(0.7rem, 1.4vw, 1rem);
    color: #ffb000;
    padding-left: 0.42em;
  }

  .sub {
    margin: 1.6rem auto 0;
    max-width: 46ch;
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 0.8rem;
    line-height: 1.7;
    color: rgba(244, 244, 245, 0.5);
    text-wrap: balance;
  }

  /* ---- metronome (conductor motif) ---- */
  .metro {
    position: relative;
    width: 64px;
    height: 92px;
    margin-bottom: 2.5rem;
  }
  .metro-body {
    position: absolute;
    left: 50%;
    bottom: 0;
    transform: translateX(-50%);
    width: 0;
    height: 0;
    border-left: 30px solid transparent;
    border-right: 30px solid transparent;
    border-bottom: 86px solid rgba(255, 255, 255, 0.06);
  }
  .metro-arm {
    position: absolute;
    left: 50%;
    bottom: 8px;
    width: 2px;
    height: 78px;
    margin-left: -1px;
    background: #ffb000;
    transform-origin: bottom center;
    box-shadow: 0 0 10px rgba(255, 176, 0, 0.7);
  }
  .metro-weight {
    position: absolute;
    left: 50%;
    top: 14px;
    width: 12px;
    height: 9px;
    transform: translateX(-50%);
    background: #ffb000;
    border-radius: 1px;
  }
  .metro-pivot {
    position: absolute;
    left: 50%;
    bottom: 6px;
    width: 7px;
    height: 7px;
    margin-left: -3.5px;
    border-radius: 50%;
    background: #f4f4f5;
  }

  /* ---- live frame-composition bar ---- */
  .composition {
    position: fixed;
    left: 0;
    right: 0;
    bottom: 84px;
    z-index: 3;
    height: 6px;
    overflow: hidden;
  }
  .composition :global(i) {
    position: absolute;
    top: 0;
    bottom: 0;
    box-shadow: inset -1px 0 0 rgba(0, 0, 0, 0.4);
  }
  .composition :global(i.t) {
    background-image: repeating-linear-gradient(
      -45deg,
      rgba(255, 255, 255, 0.22) 0 4px,
      transparent 4px 8px
    );
  }
  .composition :global(u) {
    position: absolute;
    top: 0;
    bottom: 0;
    background: rgba(255, 77, 77, 0.25);
  }

  /* ---- readout ---- */
  .readout {
    position: fixed;
    left: 0;
    right: 0;
    bottom: 0;
    z-index: 3;
    display: flex;
    align-items: center;
    gap: clamp(1.5rem, 5vw, 4rem);
    padding: 14px clamp(1rem, 4vw, 2.5rem) 16px;
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    font-variant-numeric: tabular-nums;
    background: linear-gradient(transparent, rgba(7, 7, 10, 0.85) 40%);
  }
  .stat {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .stat .k {
    font-size: 0.6rem;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: rgba(244, 244, 245, 0.4);
  }
  .stat .v {
    font-size: 1.5rem;
    font-weight: 600;
  }
  .load {
    margin-left: auto;
  }
  .load input {
    width: clamp(120px, 18vw, 220px);
    accent-color: #ffb000;
    cursor: pointer;
  }

  .toggle {
    align-self: center;
    min-width: 64px;
    padding: 8px 14px;
    border: 1px solid rgba(255, 255, 255, 0.18);
    border-radius: 6px;
    background: transparent;
    color: #f4f4f5;
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    cursor: pointer;
    transition: border-color 0.15s ease, color 0.15s ease;
  }
  .toggle:hover {
    border-color: #ffb000;
    color: #ffb000;
  }
  .toggle.paused {
    border-color: #7ddc7d;
    color: #7ddc7d;
  }

  @media (prefers-reduced-motion: reduce) {
    .metro-arm {
      transform: none !important;
    }
  }
</style>
